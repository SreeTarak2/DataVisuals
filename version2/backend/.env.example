# ============================================
# DATABASE CONFIGURATION
# ============================================
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=datasage_ai

# ============================================
# SECURITY & AUTHENTICATION
# ============================================
# Generate a secure secret key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production-use-strong-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=50

# ============================================
# OPENROUTER API (PRIMARY LLM PROVIDER)
# ============================================
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
USE_OPENROUTER=true

# Hugging Face Configuration
HUGGINGFACE_API_KEY=your-huggingface-api-key-here

# ============================================
# OLLAMA / LOCAL MODELS (CURRENTLY DISABLED)
# ============================================
# Uncomment these if you want to enable local Ollama models
# LLAMA_BASE_URL=http://localhost:11434
# QWEN_BASE_URL=http://localhost:11434
# LLM_PRIMARY_MODEL=llama3.1

# ============================================
# VECTOR DATABASE (FAISS)
# ============================================
VECTOR_DB_PATH=./faiss_db
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
ENABLE_VECTOR_SEARCH=true

# ============================================
# CORS CONFIGURATION
# ============================================

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:3000

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=csv,xlsx,xls

# ============================================
# MODEL CONFIGURATION
# ============================================
MODEL_HEALTH_CHECK_TIMEOUT=180
MODEL_FALLBACK_ENABLED=false

#=======================================
# DELAY REQUESTS TO AVOID OPENROUTER 429 RATE LIMITS
#=======================================
LLM_MAX_CONCURRENT_CALLS=2     
LLM_REQUEST_STAGGER_SECONDS=1.0 
