# ============================================
# DATABASE CONFIGURATION
# ============================================
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=datasage_ai

# ============================================
# SECURITY & AUTHENTICATION
# ============================================
# Generate a secure secret key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production-use-strong-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=50

# ============================================
# DATABASE CREDENTIAL ENCRYPTION (MUST BE SEPARATE FROM SECRET_KEY)
# ============================================
# Used to encrypt stored database connection passwords at rest.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# If not set, falls back to SECRET_KEY with a warning (not recommended for production).
DB_ENCRYPTION_KEY=your-db-encryption-key-change-in-production

# ============================================
# OPENROUTER API (PRIMARY LLM PROVIDER)
# ============================================
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
USE_OPENROUTER=true

# Hugging Face Configuration
HUGGINGFACE_API_KEY=your-huggingface-api-key-here

# ============================================
# OLLAMA / LOCAL MODELS (CURRENTLY DISABLED)
# ============================================
# Uncomment these if you want to enable local Ollama models
# LLAMA_BASE_URL=http://localhost:11434
# QWEN_BASE_URL=http://localhost:11434
# LLM_PRIMARY_MODEL=llama3.1

# ============================================
# VECTOR DATABASE (FAISS)
# ============================================
VECTOR_DB_PATH=./faiss_db
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
ENABLE_VECTOR_SEARCH=true

# ============================================
# CORS CONFIGURATION
# ============================================

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:3000

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=csv,xlsx,xls

# ============================================
# MODEL CONFIGURATION
# ============================================
MODEL_HEALTH_CHECK_TIMEOUT=180
MODEL_FALLBACK_ENABLED=false

#=======================================
# DELAY REQUESTS TO AVOID OPENROUTER 429 RATE LIMITS
#=======================================
LLM_MAX_CONCURRENT_CALLS=2     
LLM_REQUEST_STAGGER_SECONDS=1.0

# ============================================
# LLM COST CONTROLS (DAILY BUDGET CAPS)
# ============================================
# Per-user daily LLM budget in cents (default: 500 = $5.00)
LLM_DAILY_BUDGET_CENTS=500
# Global daily LLM budget in cents (default: 10000 = $100.00)
LLM_GLOBAL_DAILY_BUDGET_CENTS=10000
# Master toggle (default: true)
LLM_COST_TRACKING_ENABLED=true

# ============================================
# KNOWLEDGE GRAPH CONFIGURATION (Phase 2)
# ============================================
# Graph database type: "falkordb" (recommended) or "neo4j"
GRAPH_DB_TYPE=falkordb

# FalkorDB Configuration (recommended - open source, fast)
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_PASSWORD=
FALKORDB_TIMEOUT=30
FALKORDB_MAX_CONNECTIONS=10

# Neo4j Alternative Configuration
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your_password

# Graph Operations
GRAPH_BATCH_SIZE=100
GRAPH_QUERY_TIMEOUT_MS=5000
AUTO_CREATE_RELATIONSHIPS=true
MIN_CONFIDENCE_FOR_RELATIONSHIP=0.50

# ============================================
# ENTITY EXTRACTION CONFIGURATION
# ============================================
ENTITY_EXTRACTION_ENABLED=true
ENTITY_EXTRACTION_SAMPLE_SIZE=100
CORRECTION_MEMORY_ENABLED=true
CORRECTION_MEMORY_PATH=./correction_memory.json 
